{
    "name": "@moises-ai/studio-core-wasm",
    "version": "0.0.3",
    "license": "LGPL-3.0-or-later",
    "publishConfig": {
        "registry": "https://npm.pkg.github.com",
        "access": "public"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./wasm-processor.js": "./dist/wasm-processor.js",
        "./wasm-offline-worker.js": "./dist/wasm-offline-worker.js",
        "./wasm/*": "./dist/wasm/*"
    },
    "files": [
        "dist/**"
    ],
    "scripts": {
        "build": "npm run build:wasm && npm run build:bundles && npm run build:api",
        "build:wasm": "sh ./build-wasm.sh",
        "build:bundles": "esbuild src/processor.ts --bundle --format=esm --platform=browser --minify --sourcemap --outfile=dist/wasm-processor.js && esbuild src/offline-worker.ts --bundle --format=esm --platform=browser --minify --sourcemap --outfile=dist/wasm-offline-worker.js",
        "build:api": "tsc --project tsconfig.build.json",
        "typecheck": "tsc --noEmit",
        "lint": "eslint \"**/*.ts\"",
        "test": "vitest run",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@moises-ai/lib-box": "*",
        "@moises-ai/lib-dsp": "*",
        "@moises-ai/lib-fusion": "*",
        "@moises-ai/lib-runtime": "*",
        "@moises-ai/lib-std": "*",
        "@opendaw/nam-wasm": "^1.2.0",
        "@moises-ai/studio-adapters": "*",
        "@moises-ai/studio-boxes": "*",
        "@moises-ai/studio-core": "*",
        "soundfont2": "^0.5.0"
    },
    "devDependencies": {
        "@opendaw/eslint-config": "*",
        "@opendaw/studio-core-processors": "*",
        "@opendaw/typescript-config": "*",
        "@types/audioworklet": "^0.0.77",
        "esbuild": "^0.25.0",
        "vitest": "^3.1.3"
    }
}
