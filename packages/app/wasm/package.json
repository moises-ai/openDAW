{
    "name": "@opendaw/app-wasm",
    "private": true,
    "version": "0.0.2",
    "type": "module",
    "scripts": {
        "wasm": "sh ./build-wasm.sh",
        "predev": "npm run wasm",
        "dev": "vite --host",
        "prebuild": "npm run wasm",
        "build": "vite build",
        "preview": "vite preview --host",
        "test:rust": ". \"$HOME/.cargo/env\" && cargo test --manifest-path ../../../crates/Cargo.toml --workspace",
        "pretest:parity": "npm run wasm",
        "test:parity": "vitest run --config vitest.config.ts",
        "pretest:sync": "npm run wasm",
        "test:sync": "vitest run --config vitest.config.ts test/sync.test.ts",
        "test": "npm run test:rust && npm run test:parity",
        "clean": "rm -rf dist public/wasm"
    },
    "dependencies": {
        "@moises-ai/lib-dom": "*",
        "@moises-ai/lib-dsp": "*",
        "@moises-ai/lib-fusion": "*",
        "@moises-ai/lib-jsx": "*",
        "@moises-ai/lib-std": "*",
        "@opendaw/nam-wasm": "^1.2.0",
        "@moises-ai/studio-enums": "*",
        "jszip": "^3.10.1",
        "soundfont2": "^0.5.0"
    },
    "devDependencies": {
        "@moises-ai/lib-box": "*",
        "@moises-ai/lib-runtime": "*",
        "@moises-ai/studio-adapters": "*",
        "@moises-ai/studio-boxes": "*",
        "sass": "^1.77.0",
        "vite": "^7.0.2",
        "vitest": "^3.1.3"
    }
}
